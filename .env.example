# Profit Decision Engine — environment variables
# Copy to .env.local and fill in whichever values you have.
# The app boots and serves mock data with ALL of these blank.

# ── Auth (required in production) ──────────────────────────────────────────
AUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Supabase Postgres URL) ─────────────────────────────────────────
DATABASE_URL=
# Optional — for `npm run supabase:unpause` (https://supabase.com/dashboard/account/tokens)
# SUPABASE_ACCESS_TOKEN=

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=

# ── Email (Resend — magic-link sign-in) ──────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Profit Decision Engine <onboarding@resend.dev>

# ── Apify (TikTok trends, retail scrapers) ────────────
APIFY_API_TOKEN=
# Set when monthly credits are exhausted (optional health warning)
# APIFY_QUOTA_EXHAUSTED=true
# Verify these actors still exist on apify.com before relying on defaults.
APIFY_TIKTOK_SEARCH_ACTOR_ID=clockworks~tiktok-scraper
APIFY_TIKTOK_TRENDING_ACTOR_ID=scrapio~tiktok-trending-hashtags-scraper

# ── Amazon SP-API ────────────────────────────────────────────────────────────
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_SELLER_ID=
AMAZON_SANDBOX=true
# Amazon price: SP-API first. Set true only if you want Apify fallback (costs credits).
# AMAZON_PRICE_VIA_APIFY=true

# ── Force mock mode (development / testing) ──────────────────────────────────
# FORCE_MOCK_DB=true
# FORCE_MOCK_STRIPE=true
# FORCE_MOCK_EMAIL=true
# FORCE_MOCK_APIFY=true
